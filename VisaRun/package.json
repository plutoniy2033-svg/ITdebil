{
  "name": "visarun",
  "version": "1.0.0",
  "description": "VisaRun — визаран-помощник для экспатов во Вьетнаме",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:all": "concurrently -n web,api -c blue,green \"vite\" \"node server/index.js\"",
    "migrate": "node server/migrate.js",
    "test": "node --test server/tests/**/*.test.js",
    "test:reminders": "node --experimental-strip-types --test server/tests/deadlineReminders.test.js",
    "test:calendar": "node --experimental-strip-types --test server/tests/calendarExport.test.js",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/leaflet": "^1.9.16",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
