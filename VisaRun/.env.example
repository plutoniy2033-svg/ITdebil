# PostgreSQL connection string (local example)
DATABASE_URL=postgresql://visarun:visarun@localhost:5432/visarun

# Required in production; any long random string for local dev
JWT_SECRET=change-me-to-a-long-random-secret

# API port
PORT=3001

# Allowed frontend origin for CORS (Vite dev server)
CORS_ORIGIN=http://localhost:5173
